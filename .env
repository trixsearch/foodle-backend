# The secret key for your local development
SECRET_KEY=django-insecure-foodle-super-secret-key-2026!

# Must be true for local development, MUST BE false in production
DEBUG=true

# Comma-separated. Use a leading dot to allow all subdomains, e.g. .foodle.com
# ALLOWED_HOSTS=localhost,127.0.0.1,.foodle.com
ALLOWED_HOSTS=localhost,127.0.0.1,.foodle.com,.localhost

# Your actual local PostgreSQL connection string
DATABASE_URL=postgres://postgres:password@localhost:5432/foodle_db

# When true, requests whose Host has no Domain row (e.g. localhost) use the public schema.
SHOW_PUBLIC_IF_NO_TENANT_FOUND=true

# CORS — allowing Vite (5173) and standard React (3000) ports
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173