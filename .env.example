# Copy to .env and fill in real values. Never commit .env.

# Required — generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# false in production
DEBUG=true

# Comma-separated. Use a leading dot to allow all subdomains, e.g. .foodle.com
ALLOWED_HOSTS=localhost,127.0.0.1,.foodle.com

# PostgreSQL (django-environ / psycopg3). Example:
# DATABASE_URL=postgres://foodle:foodle@localhost:5432/foodle
DATABASE_URL=

# When true, requests whose Host has no Domain row (e.g. localhost) use the public schema.
# Set false in production if every host must map to a Domain record.
SHOW_PUBLIC_IF_NO_TENANT_FOUND=true

# CORS — comma-separated origins for the React app, e.g. http://localhost:3000,https://app.foodle.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
